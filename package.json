{
  "name": "@motion-proto/live-tokens",
  "version": "0.18.2",
  "type": "module",
  "description": "Design token editor with live CSS variable editing. Svelte 5 + Vite 8.",
  "keywords": [
    "svelte",
    "vite",
    "design-tokens",
    "css-variables",
    "editor"
  ],
  "license": "MIT",
  "author": "Mark Pearce <mark@motionproto.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motionproto/live-tokens.git"
  },
  "homepage": "https://github.com/motionproto/live-tokens",
  "bugs": "https://github.com/motionproto/live-tokens/issues",
  "files": [
    "src/editor",
    "src/system",
    "src/app/site.css",
    "src/live-tokens/data/tokens.generated.css",
    "dist-plugin",
    ".claude/skills",
    "bin",
    "!**/*.test.ts",
    "!**/*.spec.ts",
    "!**/__tests__/**",
    "!src/system/components/Stat.svelte",
    "!src/system/components/StatEditor.svelte"
  ],
  "bin": {
    "live-tokens": "./bin/cli.mjs"
  },
  "exports": {
    ".": {
      "svelte": "./src/editor/index.ts",
      "types": "./src/editor/index.ts",
      "default": "./src/editor/index.ts"
    },
    "./component-editor": {
      "svelte": "./src/editor/component-editor/index.ts",
      "types": "./src/editor/component-editor/index.ts",
      "default": "./src/editor/component-editor/index.ts"
    },
    "./ui": {
      "svelte": "./src/editor/ui/index.ts",
      "types": "./src/editor/ui/index.ts",
      "default": "./src/editor/ui/index.ts"
    },
    "./editor": {
      "types": "./src/editor/pages/Editor.svelte.d.ts",
      "svelte": "./src/editor/pages/Editor.svelte",
      "default": "./src/editor/pages/Editor.svelte"
    },
    "./component-editor-page": {
      "types": "./src/editor/pages/ComponentEditorPage.svelte.d.ts",
      "svelte": "./src/editor/pages/ComponentEditorPage.svelte",
      "default": "./src/editor/pages/ComponentEditorPage.svelte"
    },
    "./components/*": {
      "svelte": "./src/system/components/*",
      "default": "./src/system/components/*"
    },
    "./vite-plugin": {
      "types": "./dist-plugin/index.d.ts",
      "import": "./dist-plugin/index.js",
      "require": "./dist-plugin/index.cjs"
    },
    "./styles/ui-editor.css": "./src/editor/styles/ui-editor.css",
    "./app/tokens.css": "./src/system/styles/tokens.css",
    "./app/tokens.generated.css": "./src/live-tokens/data/tokens.generated.css",
    "./app/site.css": "./src/app/site.css",
    "./app/fonts.css": "./src/system/styles/fonts.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:plugin": "tsup",
    "build:lib": "npm run build:plugin",
    "deploy:local": "bash scripts/deploy-local.sh",
    "check:no-style-imports": "node scripts/check-no-style-imports.mjs",
    "check:editor-font-isolation": "node scripts/check-editor-font-isolation.mjs",
    "check:smoke-install": "bash scripts/smoke-install.sh",
    "prepublishOnly": "npm run check:no-style-imports && npm run check:editor-font-isolation && npm run build:lib && npm run check:smoke-install"
  },
  "peerDependencies": {
    "sass": "^1.0",
    "svelte": "^5",
    "svelte-preprocess": "^6.0",
    "vite": "^8"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.1",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "sass": "^1.98.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0"
  }
}
